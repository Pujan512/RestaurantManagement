@{
	ViewData["Title"] = "Home Page";
}

<div class="px-3" style="width:95%">
	@if (User.Identity.IsAuthenticated)
	{
		<h2>
			Welcome Back! @ViewBag.UserName&#128075;
		</h2>
		<h4>Today is <strong>@DateTime.Now.ToString("dddd, MMMM d")</strong></h4>
	}

	@if (User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
	{
		<div class="d-flex flex-wrap p-3 rounded gap-5 fs-5 mt-4">
			<div class="p-4 border border-dark rounded-3 shadow-lg flex-grow-1" style=" max-width: 400px; min-width: 300px;">
				<h4 class="fw-bold text-primary mb-3">
					<i class="bi bi-person-badge me-2"></i>Basic Information
				</h4>
				<hr class="my-2" />
				<div class="d-flex flex-column gap-3">
					<div>
						<span class="text-muted small">Name</span>
						<div class="fw-semibold">@ViewBag.UserName</div>
					</div>
					<div>
						<span class="text-muted small">Role</span>
						<div class="badge bg-info text-dark">@ViewBag.Role</div>
					</div>
					<div>
						<span class="text-muted small">Email</span>
						<div class="fw-semibold text-truncate">@ViewBag.Email</div>
					</div>
				</div>
			</div>

			<div class="p-4 border border-dark rounded-3 shadow-lg flex-grow-1" style=" max-width: 400px; min-width: 300px;">
				<h4 class="fw-bold text-primary mb-3">
					<i class="bi bi-clock-history me-2"></i>Today's Shift
				</h4>
				<hr class="my-2" />
				<div class="d-flex flex-column gap-3">
					<div>
						<span class="text-muted small">Clock In</span>
						<div class="fw-semibold">@ViewBag.ShiftStart</div>
					</div>
					<div>
						<span class="text-muted small">Clock Out</span>
						<div class="fw-semibold">@ViewBag.ShiftEnd</div>
					</div>
					<div>
						<span class="text-muted small">Break Time</span>
						<div class="fw-semibold">30 minutes</div>
					</div>
				</div>
			</div>
		</div>
	}

	@if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
	{
		<div class="d-flex gap-5 justify-content-between mt-4 w-100">
			<div class="d-grid gap-3 w-25" style="grid-template-rows: repeat(4, 1fr); min-width:250px">
				<div class="p-3 rounded text-dark" style="background: #F35C5C">
					<h3 class="d-flex justify-content-between">@ViewBag.OrdersCount <img src="~/Images/order.png" width="40" /></h3>
					<div>Today's Order</div>
				</div>
				<div class="bg-warning p-3 rounded text-dark">
					<h3 class="d-flex justify-content-between">@ViewBag.PendingOrdersCount <img src="~/Images/cooking.png" width="40" /></h3>
					<div>Pending Orders</div>
				</div>
				<div class="bg-info p-3 rounded text-dark">
					<h3 class="d-flex justify-content-between">@ViewBag.Earnings <i class="bi bi-cash-stack text-dark"></i></h3>
					<div>Today's Earning</div>
				</div>
				<div class="bg-success p-3 rounded text-dark">
					<h3 class="d-flex justify-content-between">@ViewBag.AvailableTablesCount <img src="~/Images/table.png" width="35" /></h3>
					<div>Available Tables</div>
				</div>
			</div>

			<div class="d-flex flex-grow-1 rounded w-75	px-4" style="background: #FFFFFFCC;">
				<canvas id="salesChart"></canvas>
			</div>

		</div>

	}
</div>
@section Scripts {
	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
	<script>
		$(document).ready(function() {
			var ctx = document.getElementById('salesChart').getContext('2d');
			var chartLabels = @Html.Raw(Json.Serialize(ViewBag.data));
			new Chart(ctx, {
		  type: 'line',
		  data: {
			labels: chartLabels.map(item => item.date),
			datasets: [{
			  label: '',
			  data: chartLabels.map(item => item.amount),
			  // backgroundColor : ['#F35C5C', '#FFCC00', '#00CCFF','#CBA0E3', '#A8E6CF', '#FFDAC1', '#B3D9FF'],
			  // borderWidth: 1
			  fill: false,
			  borderColor: '#F35C5C',
			  tension: 0.1
			}]
		  },
		  options: {
			  plugins:{
				title: {
					display: true,
					text: "Earnings Graph of a week"
				}
			  },
			  maintainAspectRatio: false,
			scales: {
			  y: {
				beginAtZero: true
			  }
			}
		  }
			});
		});
	</script>
}