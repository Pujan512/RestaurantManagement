@model RestaurantManagement.Core.ViewModels.Schedule.ScheduleVM

@{
	ViewData["Title"] = "Delete";
}
<div class="d-flex justify-content-center align-items-center flex-column h-100">
	<div class="container w-auto shadow rounded-lg p-5">
		<h3>Are you sure you want to delete this?</h3>
		<div>
			<h4>Schedule</h4>
			<hr />
			<dl class="row">
				<dt class="col-sm-2">
					Role
				</dt>
				<dd class="col-sm-10">
					@Html.DisplayFor(model => model.UserVM.FirstName) @Html.DisplayFor(model => model.UserVM.MiddleName) @Html.DisplayFor(model => model.UserVM.LastName)
				</dd>
				<dt class="col-sm-2">
					User
				</dt>
				<dd class="col-sm-10">
					@Html.DisplayFor(model => model.UserVM.Role)
				</dd>
				<dt class="col-sm-2">
					@Html.DisplayNameFor(model => model.ShiftStart)
				</dt>
				<dd class="col-sm-10">
					@Html.DisplayFor(model => model.ShiftStart)
				</dd>
				<dt class="col-sm-2">
					@Html.DisplayNameFor(model => model.ShiftEnd)
				</dt>
				<dd class="col-sm-10">
					@Html.DisplayFor(model => model.ShiftEnd)
				</dd>
			</dl>

			<form asp-action="Delete">
				<input type="hidden" asp-for="Id" />
				<input type="submit" value="Delete" class="btn btn-danger" /> 
				<a asp-action="Index" class="btn btn-secondary">Cancel</a>
			</form>
		</div>
	</div>
</div>
