@model RestaurantManagement.Core.ViewModels.Schedule.AddScheduleVM

@{
	ViewData["Title"] = "Create";
}

<nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
	<ol class="breadcrumb">
		<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Homepage</a></li>
		<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Schedule" class="text-decoration-none">Schedules</a></li>
		<li class="breadcrumb-item active" aria-current="page">Add Schedule</li>
	</ol>
</nav>

<div class="d-flex justify-content-center align-items-center flex-column" style="height:90%">
	<div class="container w-auto shadow rounded-lg p-5">
		<h3>Create Schedule</h3>

		<hr />
		<form asp-action="Create" class="d-flex gap-3 flex-column">
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			<div class="form-group" style="grid-column: span 2">
				<label asp-for="UserId" class="control-label">User</label>
				<select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId"></select>
			</div>
			<div class="d-flex gap-3">
				<div class="form-group">
					<label asp-for="ShiftStart" class="control-label">Shift Start</label>
					<input asp-for="ShiftStart" class="form-control" type="time" />
					<span asp-validation-for="ShiftStart" class="text-danger"></span>
				</div>
				<div class="form-group">
					<label asp-for="ShiftEnd" class="control-label">Shift End</label>
					<input asp-for="ShiftEnd" class="form-control" type="time" />
					<span asp-validation-for="ShiftEnd" class="text-danger"></span>
				</div>
			</div>
			<div class="form-group">
				<input type="submit" value="Create" class="btn btn-primary w-100" />
			</div>
		</form>
	</div>
</div>
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
