@model RestaurantManagement.Core.ViewModels.SystemSetting.EditSettingVM

@{
    ViewData["Title"] = "Edit";
}

<nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Homepage</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="SystemSetting" class="text-decoration-none">Settings</a></li>
        <li class="breadcrumb-item">Edit Settings</li>
    </ol>
</nav>

<h4>Edit System Setting</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="VAT" class="control-label"></label>
                <input asp-for="VAT" class="form-control" type="number"/>
                <span asp-validation-for="VAT" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ServiceCharge" class="control-label"></label>
                <input asp-for="ServiceCharge" class="form-control" type="number"/>
                <span asp-validation-for="ServiceCharge" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Update" class="btn btn-primary mt-3" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
