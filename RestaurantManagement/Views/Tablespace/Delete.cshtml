@using RestaurantManagement.Core.ViewModels.Tablespace
@model TablespaceVM

@{
	ViewData["Title"] = "Delete";
}

<div class="d-flex justify-content-center align-items-center flex-column h-100">
	<div class="container w-auto shadow rounded p-5" style="background: #FFFFFF55">
		<h3>Are you sure you want to delete this?</h3>
		<div>
			<h4>Tablespace</h4>
			<hr />
			<dl class="row">
				<dt class="col-sm-5">
					@Html.DisplayNameFor(model => model.TableNumber)
				</dt>
				<dd class="col-sm-7">
					@Html.DisplayFor(model => model.TableNumber)
				</dd>
				<dt class="col-sm-5">
					@Html.DisplayNameFor(model => model.IsOccupied)
				</dt>
				<dd class="col-sm-7">
					@(Model.IsOccupied ? "Yes" : "No")
				</dd>
				<dt class="col-sm-5">
					@Html.DisplayNameFor(model => model.Capacity)
				</dt>
				<dd class="col-sm-7">
					@Html.DisplayFor(model => model.Capacity)
				</dd>
			</dl>

			<form asp-action="Delete">
				<input type="hidden" asp-for="Id" />
				<input type="submit" value="Delete" class="btn btn-danger" />
				<a asp-action="Index" class="text-decoration-none btn btn-secondary">Cancel</a>
			</form>
		</div>
	</div>
</div>
