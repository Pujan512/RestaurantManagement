@using RestaurantManagement.Core.ViewModels.Order
@model OrderVM

@{
	ViewData["Title"] = "Details";
}

<style>
	input[type="number"]::-webkit-outer-spin-button,
	input[type="number"]::-webkit-inner-spin-button {
		-webkit-appearance: none;
		margin: 0;
	}

	input[type="number"] {
		-moz-appearance: textfield;
	}
</style>

<div>
	<nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
		<ol class="breadcrumb">
			<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Homepage</a></li>
			@if (User.Identity!.IsAuthenticated && User.IsInRole("Waiter"))
			{
				<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Tablespace" class="text-decoration-none">Tables</a></li>
				<li class="breadcrumb-item"><a asp-action="Details" asp-controller="Tablespace" asp-route-id="@Model.TablespaceId" class="text-decoration-none">Tables #@Model.TablespaceId</a></li>
				<li class="breadcrumb-item active" aria-current="page">Order #@Model.Id</li>
			}
			else
			{
				<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Order" class="text-decoration-none">Orders</a></li>
				<li class="breadcrumb-item active" aria-current="page">Order #@Model.Id</li>

			}
		</ol>
	</nav>
	<div>
		<h3>Order #@Model.Id</h3>
		<p class="text-muted">
			<strong>@Html.DisplayNameFor(model => model.OrderTime):</strong>
			@Html.DisplayFor(model => model.OrderTime)
		</p>
	</div>
</div>
<hr />

@if (Model.OrderItemVMs != null && Model.OrderItemVMs.Any())
{
	<div class="d-flex gap-5 flex-wrap	">
		@foreach (var item in Model.OrderItemVMs)
		{
			<div class="rounded-3 p-4 d-flex flex-column shadow position-relative">
				<img class="mt-3" src="@item.MenuItemVM.ImageUrl" width="175" height="150" />
				<div>
					<h4 class="fw-bold">@item.MenuItemVM.Name (@item.Quantity)</h4>
					<h5>Rs. @((item.MenuItemVM.Price - (item.MenuItemVM.Price * item.MenuItemVM.Discount / 100)).ToString("F2"))</h5>
					<span>
						<span class="text-decoration-line-through">Rs.@item.MenuItemVM.Price </span> &nbsp; -@item.MenuItemVM.Discount%
					</span>
					<p class="text-secondary mb-0 pb-0">@item.MenuItemVM.Description</p>
				</div>
				<div class="btn-group position-absolute top-0 end-0 me-2 d-flex align-items-center" style="z-index:9">
					@if (Model.Status != "Ready" && User.Identity!.IsAuthenticated && (User.IsInRole("Waiter") || User.IsInRole("Admin")))
					{
						<div class="edit">
							<i class="bi bi-pencil-square text-secondary fs-4 me-1"></i>
						</div>
						<a asp-action="Delete" asp-route-id="@item.Id" asp-controller="OrderItem">
							<i class="bi bi-trash text-danger fs-3"></i>
						</a>

					}
				</div>
				<div class="editForm d-none mt-2">
					<form asp-action="Edit" asp-route-id="@item.Id" asp-controller="OrderItem">
						<input type="hidden" id="Id" name="Id" value="@item.Id" />
						<input type="hidden" id="OrderId" name="OrderId" value="@item.OrderId" />
						<input type="hidden" id="MenuItemId" name="MenuItemId" value="@item.MenuItemId" />

						<div class="form-group d-flex flex-column" style="width:175px">
							<label for="Quantity" class="control-label">Quantity</label>
							<input id="Quantity" name="Quantity" class="form-control" type="number" required value="@item.Quantity" />
						</div>
						<div class="cancel position-absolute top-0 end-0 me-2" style="cursor: pointer">
							<i class="bi bi-x-circle text-danger fs-4"></i>
						</div>
					</form>
				</div>
			</div>
		}
		@if (@Model.Status != "Ready" && User.Identity!.IsAuthenticated && User.IsInRole("Waiter"))
		{
			<div class="rounded-3 p-4 shadow" style="background:#FDE0DDFF; width: 215px; min-height: 250px;">
				<a asp-route-id="@Model.Id" asp-action="Create" asp-controller="OrderItem" class="text-decoration-none w-100 h-100 d-flex align-items-center justify-content-center ">
					<span class="fs-3 text-center d-flex flex-column" style="color: #CC4C11ff"><i class="bi bi-plus-lg fs-1"></i>Add new order item</span>
				</a>
			</div>
		}
	</div>
}
else
{
	@if (@Model.Status != "Ready" && User.Identity!.IsAuthenticated && User.IsInRole("Waiter"))
	{
		<div class="rounded-3 p-2 shadow" style="background:#FDE0DDFF; width: 200px">
			<a asp-route-id="@Model.Id" asp-action="Create" asp-controller="OrderItem" class="text-decoration-none w-100 h-100 d-flex align-items-center justify-content-center ">
				<span class="fs-3 text-center d-flex flex-column" style="color: #CC4C11ff"><i class="bi bi-plus-lg fs-1"></i>Add new order item</span>
			</a>
		</div>
	}
	<div class="alert alert-info mt-4" role="alert">
		<i class="bi bi-info-circle-fill me-2"></i> No order items found for this order.
	</div>

}

@section Scripts {
	<script>
		$(document).ready(function() {
			$(".edit").click(function(){
				$(this).parent().siblings().not("img").addClass("d-none");
				$(this).parent().addClass("d-none");
				$(this).parent().siblings(".editForm").removeClass("d-none").addClass("card-body");
			})

			$('input[type="number"]').change(function() {
					$(this).closest("form").submit();
			});

			$(".cancel").click(function(){
			location.reload();
		})
		});
	</script>
}
