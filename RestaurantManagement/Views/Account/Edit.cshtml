@model RestaurantManagement.Core.ViewModels.Account.EditUserVM

@{
    ViewBag.Title = "Edit-User";
}

<nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
	<ol class="breadcrumb">
		<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Homepage</a></li>
		<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Account" class="text-decoration-none">Users</a></li>
		<li class="breadcrumb-item active" aria-current="page">Edit User</li>
	</ol>
</nav>

<div class="container py-4">
	<div class="row justify-content-center">
		<div class="p-5 shadow-lg" style="width:50%; border-radius:10px">
			<div class="d-flex justify-content-center align-items-center flex-column">
				<h2 class="mt-0 mb-3">Edit User</h2>
				<div>
					<form method="post">
						<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

						<div class="row mb-2">
							<div class="col-md-4 mb-3">
								@* <label asp-for="FirstName" class="form-label m-0 ms-2"></label>  *@
								<input asp-for="FirstName" class="form-control" required style="border-radius: 5px" placeholder="First Name" />
								<span asp-validation-for="FirstName" class="text-danger small"></span>
							</div>

							<div class="col-md-4 mb-3">
								 @* <label asp-for="MiddleName" class="form-label m-0 ms-2"></label>  *@
								<input asp-for="MiddleName" class="form-control" style="border-radius: 5px" placeholder="Middle Name" />
								<span asp-validation-for="MiddleName" class="text-danger small"></span>
							</div>

							<div class="col-md-4 mb-3">
								@* <label asp-for="LastName" class="form-label m-0 ms-2"></label> *@
								<input asp-for="LastName" class="form-control" required style="border-radius: 5px" placeholder="Last Name" />
								<span asp-validation-for="LastName" class="text-danger small"></span>
							</div>
						</div>

						<div class="row">
							<div class="col-md-12 mb-3">
								@* <label asp-for="Status" class="form-label m-0 ms-2"></label> *@
								<select asp-for="Status" class="form-select" required style="border-radius: 5px">
									<option value="">Select Status</option>
									<option value="Approved">Approved</option>
									<option value="Disabled">Disabled</option>
								</select>
								<span asp-validation-for="Status" class="text-danger small"></span>
							</div>

							<div class="col-md-12 mb-3">
								@* <label asp-for="Role" class="form-label m-0 ms-2"></label> *@
								<select asp-for="Role" class="form-select" required style="border-radius: 5px">
									<option value="">Select Role</option>
									<option value="Admin">Admin</option>
									<option value="Waiter">Waiter</option>
									<option value="Cashier">Cashier</option>
									<option value="Cook">Cook</option>
								</select>
								<span asp-validation-for="Role" class="text-danger small"></span>
							</div>
						</div>

						<div class="d-flex row mt-3 justify-content-center">
							<button type="submit" class="btn btn-primary" style="width: 95%; border-radius: 5px">Update</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

