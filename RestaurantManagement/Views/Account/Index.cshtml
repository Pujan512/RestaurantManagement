@using RestaurantManagement.Core.ViewModels.Account
@model IEnumerable<UserVM>

@{
	ViewData["Title"] = "Index";
}

<nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
	<ol class="breadcrumb">
		<li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Homepage</a></li>
		<li class="breadcrumb-item active" aria-current="page">Users</li>
	</ol>
</nav>

<div class="d-flex justify-content-between mb-4">
	<h3>Users</h3>
	<a asp-action="Create" class="btn btn-primary"> Add User</a>
</div>

<table class="table table-hover">
	<thead class="table-info">
		<tr>
			<th>Name</th>
			<th>Email Address</th>
			<th>Role</th>
			<th class="text-end">Status</th>
			<th class="text-end">Action</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr class="bill position-relative" data-table-id="@item.Id">
				<td>
					@Html.DisplayFor(modelItem => item.FirstName) @Html.DisplayFor(modelItem => item.MiddleName) @Html.DisplayFor(modelItem => item.LastName)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Email)
				</td>
				<td>@(item.Role == "Admin" ? "Manager" : item.Role)</td>
				<td class="text-end">
					<span class="badge @(item.Status == "Approved" ? "bg-success" : item.Status == "Disabled" ? "bg-danger" : "bg-secondary")">
						@Html.DisplayFor(modelItem => item.Status)
					</span>
				</td>
				<td class="text-end fs-4 d-flex justify-content-end gap-3">
					@if (item.Status == "Approved")
					{
						<form asp-action="Edit" asp-route-id="@item.Id">
							<input type="hidden" id="Id" name="Id" value="@item.Id" />
							<input type="hidden" id="FirstName" name="FirstName" value="@item.FirstName" />
							<input type="hidden" id="MiddleName" name="MiddleName" value="@item.MiddleName" />
							<input type="hidden" id="LastName" name="LastName" value="@item.LastName" />
							<input type="hidden" id="Role" name="Role" value="@item.Role" />
							<input type="hidden" id="Status" name="Status" value="Disabled" />
							<button class="btn btn-secondary">
								Disable
							</button>
						</form>
					}
					else
					{
						<form asp-action="Edit" asp-route-id="@item.Id">
							<input type="hidden" id="Id" name="Id" value="@item.Id" />
							<input type="hidden" id="FirstName" name="FirstName" value="@item.FirstName" />
							<input type="hidden" id="MiddleName" name="MiddleName" value="@item.MiddleName" />
							<input type="hidden" id="LastName" name="LastName" value="@item.LastName" />
							<input type="hidden" id="Role" name="Role" value="@item.Role" />
							<input type="hidden" id="Status" name="Status" value="Approved" />
							@if (item.Status == "Pending")
							{
								<button class="btn btn-primary">
									Approve
								</button>
							} else
							{
								<button class="btn btn-primary">
									Enable
								</button>								
							}
						</form>
					}
					<a asp-action="Edit" asp-route-id="@item.Id" class="text-decoration-none">
						<i class="bi bi-pencil-square text-secondary me-1"></i>
					</a>
					<a asp-action="Delete" asp-route-id="@item.Id">
						<i class="bi bi-trash text-danger"></i>
					</a>
				</td>
			</tr>
		}
	</tbody>
</table>
