@model RestaurantManagement.Core.ViewModels.Bill.BillVM

@{
    ViewData["Title"] = "Create";
}

<nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Homepage</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Tablespace" class="text-decoration-none">Tables</a></li>
        <li class="breadcrumb-item"><a asp-action="Details" asp-controller="Tablespace" asp-route-id="@Model.TablespaceId" class="text-decoration-none">Table #@Model.Tablespace.TableNumber</a></li>
        <li class="breadcrumb-item active" aria-current="page">Create Bill</li>
    </ol>
</nav>

<div class="w-50 shadow-lg p-5 d-flex flex-column gap-2 rounded mx-auto">
    <h2 class="text-center">Restaurant Management</h2>
    <h4 class="text-center">Bill</h4>
    <div class="d-flex justify-content-between">
        <span>Tablespace No.: #@Model.Tablespace.TableNumber</span>
        <span>@Model.Timestamp</span>
    </div>

    <div class="d-grid fw-bold" style="grid-template-columns:repeat(6, 1fr); border-top: 2px dashed black; border-bottom: 2px dashed black">
        <span style="grid-column: span 2">Item</span>
        <span>Quantity</span>
        <span>Unit</span>
        <span>Discount(%)</span>
        <span class="text-end">Total Amt.</span>
    </div>

    <div class="d-grid" style="grid-template-columns:repeat(6, 1fr)">
        @foreach (var order in Model.OrderVMs)
        {
            @foreach (var orderItem in order.OrderItemVMs)
            {
                <div style="grid-column: span 2">@orderItem.MenuItemVM.Name</div>
                <div>@orderItem.Quantity</div>
                <div>@orderItem.MenuItemVM.Price</div>
                <div>@orderItem.MenuItemVM.Discount</div>
                <div class="text-end">@(((orderItem.MenuItemVM.Price - (orderItem.MenuItemVM.Discount * orderItem.MenuItemVM.Price / 100)) * orderItem.Quantity).ToString("F2"))</div>
            }
        }
    </div>
    <div class="d-flex justify-content-between" style="border-top: 2px dashed black">
        <span>Grand Total</span>
        <span>@((Model.SubTotal).ToString("F2"))</span>
    </div>

    <div class="d-flex justify-content-between">
        <span>VAT (@Model.VATPercent%)</span>
        <span>@((Model.VAT).ToString("F2"))</span>
    </div>

    <div class="d-flex justify-content-between">
        <span>Service Charge (@Model.ServiceChargePercent%)</span>
        <span>@((Model.ServiceCharge).ToString("F2"))</span>
    </div>

    <div class="d-flex justify-content-between" style="border-top: 2px dashed black; border-bottom: 2px dashed black">
        <span>Net Total</span>
        <span>@((Model.TotalAmount).ToString("F2"))</span>
    </div>

    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group d-flex justify-content-end gap-2 align-items-center">
            <label asp-for="PaymentType" class="control-label"></label>
            <select asp-for="PaymentType" class="form-select w-25">
                <option value="Cash">Cash</option>
                <option value="Online">Online</option>
            </select>
            <span asp-validation-for="PaymentType" class="text-danger"></span>
        </div>

        <div class="form-group">
            <input type="submit" value="Create" class="btn btn-primary" />
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
